{% extends 'base.html.twig' %}

{% block title %}ePontaje | Cereri de alăturare — {{ company.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_company') }}" class="text-decoration-none text-muted fw-medium">
                            <i class="bi bi-building me-1"></i>{{ company.name }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active fw-semibold text-dark" aria-current="page">Cereri de alăturare</li>
                </ol>
            </nav>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="fw-bold mb-0">Cereri de alăturare</h2>
                    <p class="text-muted small mb-0">{{ requests|length }} {{ requests|length == 1 ? 'cerere în așteptare' : 'cereri în așteptare' }}</p>
                </div>
            </div>

            {% if requests is empty %}
                <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                        <h5 class="fw-semibold text-muted">Nu există cereri în așteptare</h5>
                        <p class="text-muted small">Când cineva dorește să se alăture companiei tale, cererea va apărea aici.</p>
                    </div>
                </div>
            {% else %}
                <div class="d-flex flex-column gap-3">
                    {% for req in requests %}
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-3 p-4">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0 shadow-sm"
                                     style="width: 48px; height: 48px; font-size: 16px;">
                                    {{ req.user.firstName|first|upper }}{{ req.user.lastName|first|upper }}
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-dark">{{ req.user.firstName }} {{ req.user.lastName }}</div>
                                    <div class="text-muted small">{{ req.user.email }}</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        <i class="bi bi-clock me-1"></i>{{ req.createdAt|date('d.m.Y H:i') }}
                                    </div>
                                </div>
                                <div class="d-flex gap-2 flex-shrink-0">
                                    <form action="{{ path('app_company_request_accept', {id: req.id}) }}" method="POST">
                                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-medium">
                                            <i class="bi bi-check-lg me-1"></i>Acceptă
                                        </button>
                                    </form>
                                    <form action="{{ path('app_company_request_reject', {id: req.id}) }}" method="POST">
                                        <button type="submit" class="btn btn-outline-danger rounded-pill px-4 fw-medium">
                                            <i class="bi bi-x-lg me-1"></i>Respinge
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
