{% extends 'base.html.twig' %}

{% block title %}Work App | {{ app.user.company.name }}{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">

                {# Cardul principal centrat #}
                <div class="card shadow-lg border-0 rounded-4 text-center p-4 p-md-5">
                    <h1 class="border-bottom pb-4 fw-semibold">{{ company.name }}</h1>

                    <div class="pt-4">
                        {# Afisarea erorilor (valabila pentru ambele roluri) #}
                        {% if app.request.query.get('error') %}
                            <div class="alert alert-danger mb-4" role="alert">
                                <i class="bi bi-exclamation-circle me-2"></i> {{ app.request.query.get('error') }}
                            </div>
                        {% endif %}

                        {% if app.user.company.owner == app.user %}
                            <form action="{{ path('app_company_change_name') }}" method="post" class="mx-auto" style="max-width: 400px;">
                                <div class="input-group mb-3 shadow-sm rounded-3">
                                    <input type="text" name="company-name" required class="form-control form-control-lg border-light-subtle" placeholder="{{ company.name }}">
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-2 rounded-3 fw-medium">Change Name</button>
                            </form>

                            <hr class="my-4 text-muted">

                            <h4 class="fw-semibold mb-3">Email Address</h4>
                            <p class="text-muted mb-1">Your email address is: <strong>{{ app.user.email }}</strong></p>
                            <a href="{{ path('app_change_email') }}" class="text-primary fw-semibold text-decoration-none small">Change</a>

                            <hr class="my-4 text-muted">

                            <h4 class="fw-semibold text-danger mb-3">Delete Company</h4>

                            <div class="badge rounded-pill bg-danger-subtle text-danger d-inline-flex align-items-center py-2 px-3 mb-3 fs-6 fw-medium">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> Proceed with caution
                            </div>

                            <p class="text-muted mb-4">
                                We will completely wipe your company with all the associated data, like work records, holidays, etc.
                                There is no way to access your company after this action.
                            </p>

                            <form action="{{ path('app_delete_company') }}" method="post" onsubmit="return confirm('Are you sure you want to delete your company?');">
                                <button type="submit" class="btn btn-outline-danger w-100 py-2 fw-semibold rounded-3">Delete Company</button>
                            </form>

                        {% else %}
                            <h4 class="fw-semibold mb-3">Owner Email</h4>
                            <p class="text-muted mb-0">Owner email address is: <strong>{{ app.user.company.owner.email }}</strong></p>

                            <hr class="my-4 text-muted">

                            <h4 class="fw-semibold text-danger mb-3">Leave Company</h4>

                            <div class="badge rounded-pill bg-danger-subtle text-danger d-inline-flex align-items-center py-2 px-3 mb-3 fs-6 fw-medium">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> Proceed with caution
                            </div>

                            <p class="text-muted mt-2">
                                Leave your current company
                            <form action="{{ path('app_leave_company') }}" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to leave the company?');">
                                <button type="submit" class="btn btn-link text-danger fw-bold p-0 align-baseline text-decoration-none">here</button>
                            </form>.
                            </p>

                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}