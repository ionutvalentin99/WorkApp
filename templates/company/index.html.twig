{% extends 'base.html.twig' %}

{% block title %}ePontaje | {{ company.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-9">

            {# ── Header companie ── #}
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center gap-4">
                        <div class="rounded-3 bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0 shadow-sm"
                             style="width: 64px; height: 64px; font-size: 22px; letter-spacing: -1px;">
                            {{ company.name|split(' ')|map(w => w|first|upper)|join('')|slice(0, 2) }}
                        </div>
                        <div>
                            <h2 class="fw-bold mb-1">{{ company.name }}</h2>
                            <div class="d-flex align-items-center gap-3 text-muted small">
                                <span><i class="bi bi-geo-alt me-1"></i>{{ company.city }}, {{ company.country }}</span>
                                <span><i class="bi bi-telephone me-1"></i>{{ company.phoneNumber }}</span>
                                {% if company.owner == app.user %}
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-1 fw-medium">
                                        <i class="bi bi-star-fill me-1"></i>Owner
                                    </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {% if company.owner == app.user %}

                {# ── Statistici ── #}
                <div class="row g-3 mb-4">
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
                            <div class="fw-bold fs-2 text-primary mb-1">{{ company.users|length }}</div>
                            <div class="text-muted small fw-medium">Angajați</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
                            <div class="fw-bold fs-2 text-warning mb-1">
                                {{ company.requests|filter(r => r.status == 'PENDING' and r.type == 'JOIN_REQUEST')|length }}
                            </div>
                            <div class="text-muted small fw-medium">Cereri în așteptare</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
                            <div class="fw-bold fs-2 text-info mb-1">
                                {{ company.requests|filter(r => r.status == 'PENDING' and r.type == 'INVITATION')|length }}
                            </div>
                            <div class="text-muted small fw-medium">Invitații trimise</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 text-center p-3 h-100">
                            <div class="fw-bold fs-2 {{ company.isPaid ? 'text-success' : 'text-danger' }} mb-1">
                                <i class="bi {{ company.isPaid ? 'bi-check-circle-fill' : 'bi-x-circle-fill' }}"></i>
                            </div>
                            <div class="text-muted small fw-medium">Abonament</div>
                        </div>
                    </div>
                </div>

                {# ── Acțiuni rapide ── #}
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-4">
                        <a href="{{ path('app_company_members') }}"
                           class="card border-0 shadow-sm rounded-4 text-decoration-none h-100 action-card">
                            <div class="card-body p-4 d-flex align-items-center gap-3">
                                <div class="rounded-3 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width: 48px; height: 48px;">
                                    <i class="bi bi-people-fill text-primary fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">Membri</div>
                                    <div class="text-muted small">Gestionează echipa</div>
                                </div>
                                <i class="bi bi-chevron-right text-muted ms-auto"></i>
                            </div>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a href="{{ path('app_company_requests') }}"
                           class="card border-0 shadow-sm rounded-4 text-decoration-none h-100 action-card">
                            <div class="card-body p-4 d-flex align-items-center gap-3">
                                <div class="rounded-3 bg-warning bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width: 48px; height: 48px;">
                                    <i class="bi bi-person-check-fill text-warning fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">Cereri</div>
                                    <div class="text-muted small">Aprobă sau respinge</div>
                                </div>
                                <i class="bi bi-chevron-right text-muted ms-auto"></i>
                            </div>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a href="{{ path('app_company_invite') }}"
                           class="card border-0 shadow-sm rounded-4 text-decoration-none h-100 action-card">
                            <div class="card-body p-4 d-flex align-items-center gap-3">
                                <div class="rounded-3 bg-success bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width: 48px; height: 48px;">
                                    <i class="bi bi-send-fill text-success fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">Invitații</div>
                                    <div class="text-muted small">Adaugă membri noi</div>
                                </div>
                                <i class="bi bi-chevron-right text-muted ms-auto"></i>
                            </div>
                        </a>
                    </div>
                </div>

                {# ── Setări companie ── #}
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold mb-4">Setări companie</h5>

                        <label class="form-label fw-medium text-muted small text-uppercase" style="letter-spacing: 0.05em;">
                            Schimbă numele companiei
                        </label>
                        <form action="{{ path('app_company_change_name') }}" method="post"
                              class="d-flex gap-2">
                            <label>
                                <input type="text" name="company-name" required
                                       class="form-control rounded-pill px-4"
                                       placeholder="{{ company.name }}">
                            </label>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-medium flex-shrink-0">
                                Salvează
                            </button>
                        </form>
                    </div>
                </div>

                {# ── Delete ── #}
                <div class="card border-0 shadow-sm rounded-4 border border-danger border-opacity-25">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold text-danger mb-1">Ștergere companie</h5>
                        <p class="text-muted small mb-4">
                            Ștergerea companiei este ireversibilă. Toate datele asociate (pontaje, concedii, cereri) vor fi șterse permanent.
                        </p>
                        <form action="{{ path('app_delete_company') }}" method="post"
                              onsubmit="return confirm('Ești sigur că vrei să ștergi compania {{ company.name }}? Această acțiune nu poate fi anulată.');">
                            <button type="submit"
                                    class="btn btn-outline-danger rounded-pill px-5 fw-semibold">
                                <i class="bi bi-trash3 me-2"></i>Șterge compania
                            </button>
                        </form>
                    </div>
                </div>

            {% else %}

                {# ── Vizualizare angajat ── #}
                <div class="row g-3 mb-4">
                    <div class="col-12 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                            <div class="text-muted small fw-medium text-uppercase mb-2" style="letter-spacing: 0.05em;">Owner</div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width: 40px; height: 40px;">
                                    {{ company.owner.firstName|first|upper }}{{ company.owner.lastName|first|upper }}
                                </div>
                                <div>
                                    <div class="fw-semibold">{{ company.owner.firstName }} {{ company.owner.lastName }}</div>
                                    <div class="text-muted small">{{ company.owner.username }}</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 p-4 h-100 text-center">
                            <div class="fw-bold fs-2 text-primary mb-1">{{ company.users|length }}</div>
                            <div class="text-muted small fw-medium">Angajați în companie</div>
                        </div>
                    </div>
                </div>

                {# ── Părăsire companie ── #}
                <div class="card border-0 shadow-sm rounded-4 border border-danger border-opacity-25">
                    <div class="card-body p-4">
                        <h5 class="fw-semibold text-danger mb-1">Părăsește compania</h5>
                        <p class="text-muted small mb-4">
                            Vei pierde accesul la toate datele companiei. Te poți alătura din nou printr-o nouă cerere.
                        </p>
                        <form action="{{ path('app_leave_company') }}" method="post"
                              onsubmit="return confirm('Ești sigur că vrei să părăsești compania {{ company.name }}?');">
                            <button type="submit" class="btn btn-outline-danger rounded-pill px-5 fw-semibold">
                                <i class="bi bi-box-arrow-left me-2"></i>Părăsește compania
                            </button>
                        </form>
                    </div>
                </div>

            {% endif %}

        </div>
    </div>
</div>

<style>
    .action-card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        cursor: pointer;
    }
    .action-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1) !important;
    }
</style>
{% endblock %}
