{% extends 'base.html.twig' %}

{% block title %}ePontaje | Invită utilizatori — {{ company.name }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_company') }}" class="text-decoration-none text-muted fw-medium">
                            <i class="bi bi-building me-1"></i>{{ company.name }}
                        </a>
                    </li>
                    <li class="breadcrumb-item active fw-semibold text-dark" aria-current="page">Invită utilizatori</li>
                </ol>
            </nav>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="fw-bold mb-0">Invită utilizatori</h2>
                    <p class="text-muted small mb-0">Caută și trimite invitații în <strong>{{ company.name }}</strong></p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <form action="{{ path('app_company_invite') }}" method="GET" class="d-flex gap-2">
                        <input type="text" name="q" value="{{ query }}" class="form-control rounded-pill px-4"
                               placeholder="Caută după nume, email sau username...">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-medium">
                            <i class="bi bi-search me-1"></i>Caută
                        </button>
                    </form>
                </div>
            </div>

            {% if query and results is empty %}
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                    Niciun utilizator găsit pentru „{{ query }}".
                </div>
            {% endif %}

            {% if results is not empty %}
                <div class="d-flex flex-column gap-3">
                    {% for u in results %}
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body d-flex align-items-center gap-3 p-3">
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0"
                                     style="width: 44px; height: 44px; font-size: 15px;">
                                    {{ u.firstName|first|upper }}{{ u.lastName|first|upper }}
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-dark">{{ u.firstName }} {{ u.lastName }}</div>
                                    <div class="text-muted small">{{ u.email }}</div>
                                </div>
                                <div class="flex-shrink-0">
                                    {% if u.id in memberIds %}
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2">
                                            <i class="bi bi-check-circle me-1"></i>Deja membru
                                        </span>
                                    {% elseif u.id in invitedUserIds %}
                                        <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2">
                                            <i class="bi bi-clock me-1"></i>Invitat
                                        </span>
                                    {% else %}
                                        <form action="{{ path('app_company_invite_send', {id: u.id}) }}" method="POST">
                                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-medium btn-sm">
                                                <i class="bi bi-send me-1"></i>Invită
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
