<!DOCTYPE html>
<html lang="ro">
<head>
    {% block head %}
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Work App{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}

            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

            <style>
                :root {
                    /* 60% - Fundal (Alice Blue) */
                    --bs-body-bg: #EBF2FA;
                    --bs-body-bg-rgb: 235, 242, 250;

                    /* 10% - Accent (Steel Azure) */
                    --bs-primary: #064789;
                    --bs-primary-rgb: 6, 71, 137;

                    /* 30% - Secundar (Steel Blue) */
                    --bs-secondary: #427AA1;
                    --bs-secondary-rgb: 66, 122, 161;

                    /* Text */
                    --bs-body-color: #212529;

                    /* Fontul */
                    --bs-font-sans-serif: 'Inter', system-ui, -apple-system, sans-serif;
                    --bs-body-font-family: var(--bs-font-sans-serif);
                }

                /* Setări globale */
                body {
                    padding-bottom: 80px;
                    min-height: 100vh;
                    display: flex;
                    flex-direction: column;
                    -webkit-font-smoothing: antialiased;
                    -moz-osx-font-smoothing: grayscale;
                }

                /* Suprascriem complet butoanele de tip primary */
                .btn-primary {
                    /* Culoarea default (Steel Blue) */
                    --bs-btn-bg: var(--bs-secondary);
                    --bs-btn-border-color: var(--bs-secondary);

                    /* Culoarea la hover (Dark/Body Color) */
                    --bs-btn-hover-bg: var(--bs-primary);
                    --bs-btn-hover-border-color: var(--bs-primary);

                    /* Culoarea activă (când dai click pe el) - o punem tot închisă */
                    --bs-btn-active-bg: #1a1d20;
                    --bs-btn-active-border-color: #1a1d20;

                    /* Asigurăm că textul rămâne mereu alb și vizibil */
                    --bs-btn-color: #fff;
                    --bs-btn-hover-color: #fff;
                    --bs-btn-active-color: #fff;
                }
            </style>
        {% endblock %}
    {% endblock %}
</head>

<body>

{% block header %}
    {% include 'PageElements/_navbar.html.twig' %}
{% endblock %}

{# Containerul pentru alerte FARA margin-top. Am mutat clasa mt-4 pe fiecare alertă în parte #}
<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-4 mt-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-4 mt-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show border-0 shadow-sm rounded-4 mt-4" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
</div>

<main class="flex-grow-1">
    {% block body %}
    {% endblock %}
</main>

{% include 'PageElements/_footer.html.twig' %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
{% endblock %}

</body>
</html>