{% extends 'base.html.twig' %}

{% block title %}ePontaje | Setări aplicație{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <h1 class="h2 fw-bold mb-4">Settings</h1>

            <div class="row">
                {% include 'PageElements/_account_sidebar.html.twig' %}

                <div class="col-12 col-lg-9">
                    <div class="card border-0 shadow-sm bg-light">
                        <div class="card-body p-4 p-md-5">

                            <div class="d-flex align-items-center gap-2 mb-1">
                                <h2 class="h4 fw-bold mb-0">Setări aplicație</h2>
                                <span class="badge bg-danger-subtle text-danger rounded-pill px-3 fw-medium" style="font-size: 0.75rem;">
                                    <i class="bi bi-shield-lock me-1"></i>Admin
                                </span>
                            </div>
                            <p class="text-muted small mb-4">Aceste setări afectează comportamentul întregii platforme.</p>
                            <hr class="mb-4 text-secondary opacity-25">

                            {# ── Înregistrări ── #}
                            <div class="d-flex align-items-start justify-content-between gap-4">
                                <div>
                                    <h5 class="fw-bold mb-1">Înregistrări noi</h5>
                                    <p class="text-muted small mb-0">
                                        Controlează dacă utilizatorii se pot înregistra pe platformă.
                                        Când este dezactivat, pagina de înregistrare afișează un mesaj de eroare.
                                    </p>
                                    <div class="mt-2">
                                        {% if registration_enabled %}
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3 py-2 fw-medium">
                                                <i class="bi bi-check-circle-fill me-1"></i>Activat
                                            </span>
                                        {% else %}
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2 fw-medium">
                                                <i class="bi bi-x-circle-fill me-1"></i>Dezactivat
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>

                                <form action="{{ path('app_admin_toggle_registration') }}" method="POST" class="flex-shrink-0">
                                    {% if registration_enabled %}
                                        <input type="hidden" name="registration_enabled" value="0">
                                        <button type="submit"
                                                class="btn btn-outline-danger rounded-pill px-4 fw-medium"
                                                onclick="return confirm('Ești sigur că vrei să dezactivezi înregistrările?');">
                                            <i class="bi bi-toggle-on me-2"></i>Dezactivează
                                        </button>
                                    {% else %}
                                        <input type="hidden" name="registration_enabled" value="1">
                                        <button type="submit"
                                                class="btn btn-success rounded-pill px-4 fw-medium">
                                            <i class="bi bi-toggle-off me-2"></i>Activează
                                        </button>
                                    {% endif %}
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
